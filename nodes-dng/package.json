{
  "name": "n8n-nodes-dng",
  "version": "3.0.1",
  "description": "DraftNGoal community node pack for n8n: ships only DNG Submit Level + DNG Scoring Webhook credential. Candidates build exam workflows with native n8n nodes and submit to the official cloud scorer.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "dist",
    "challenges"
  ],
  "homepage": "https://dng.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/voltek62/n8n-nodes-dng.git"
  },
  "bugs": {
    "url": "https://github.com/voltek62/n8n-nodes-dng/issues"
  },
  "author": "Vincent Terrasi <hello@dng.ai> (https://dng.ai)",
  "engines": {
    "node": ">=20"
  },
  "n8n": {
    "credentials": [
      "dist/credentials/DngScoringWebhook.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DngSubmitLevel/DngSubmitLevel.node.js"
    ]
  },
  "scripts": {
    "build": "npm run sanitize && tsc",
    "sanitize": "node scripts/sanitize-challenges.mjs",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "n8n-nodes",
    "dng",
    "draftngoal",
    "exam",
    "workflow",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "n8n-workflow": "1.82.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
